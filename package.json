{
  "name": "rig-cli",
  "version": "0.1.2",
  "description": "AI agent orchestration framework for automating the software development lifecycle with Claude AI",
  "type": "module",
  "bin": {
    "rig": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zachstecko/rig-cli.git"
  },
  "keywords": [
    "agent-orchestration",
    "ai-agents",
    "multi-agent-system",
    "agent-framework",
    "ai-orchestration",
    "claude-ai",
    "llm-orchestration",
    "autonomous-agents",
    "cli",
    "automation",
    "github",
    "ai",
    "workflow",
    "pipeline",
    "development",
    "devtools",
    "code-generation",
    "ai-powered"
  ],
  "author": "Zach Stecko",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "demo-logger": "tsx demo-logger.ts"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.19.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
